%% 开题报告技术路线图 — mermaid.live
%% 布局：row1-->row2 连线；方法在虚线框外；p1-p4 虚线框

%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontFamily": "SimSun, Microsoft YaHei, serif",
    "fontSize": "13px",
    "primaryColor": "#ffffff",
    "primaryTextColor": "#000000",
    "primaryBorderColor": "#000000",
    "secondaryColor": "#ffffff",
    "tertiaryColor": "#ffffff",
    "lineColor": "#000000",
    "clusterBkg": "transparent",
    "clusterBorder": "#888888",
    "titleColor": "#000000",
    "background": "#ffffff"
  },
  "flowchart": {
    "curve": "linear",
    "htmlLabels": false,
    "padding": 10,
    "nodeSpacing": 18,
    "rankSpacing": 24
  },
  "themeCSS": ".node rect,.node polygon,.node path{fill:#fff!important;stroke:#000!important;filter:none!important}.edgePath .path,.flowchart-link{stroke:#000!important}.marker{fill:#000!important;stroke:#000!important}.cluster-label{display:none!important}.cluster rect{fill:transparent!important;filter:none!important}"
}}%%

flowchart TB
    classDef method fill:#ffffff,stroke:#000000,stroke-width:1.5px,color:#000000
    classDef box fill:#ffffff,stroke:#000000,stroke-width:1px,color:#000000
    classDef endbox fill:#ffffff,stroke:#000000,stroke-width:1.5px,color:#000000

    subgraph row1[" "]
        direction LR
        M1["文献研究法"]:::method
        subgraph p1[" "]
            direction TB
            A1["问题界定与文献综述"]:::box
            A1 --> B1["研究背景与意义"]:::box
            A1 --> B2["国内外文献综述"]:::box
            A1 --> B3["研究内容与目标"]:::box
        end
        M1 ~~~ A1
    end

    subgraph row2[" "]
        direction LR
        M2["离散事件仿真法"]:::method
        subgraph p2[" "]
            direction TB
            C1["脱敏数据"]:::box
            C2["Simio六工序DES建模"]:::box
            D1["多级批次链结构"]:::box
            D2["搬运、转入转出与换型约束"]:::box
            C1 --> C2
            C2 --> D1
            C2 --> D2
        end
        M2 ~~~ C1
    end

    subgraph row3[" "]
        direction LR
        M3["仿真优化实验设计法"]:::method
        subgraph p3[" "]
            direction TB
            E1["仿真绩效指标体系构建"]:::box
            E2["Scenario Generator<br/>批次因子网格扫描"]:::box
            E3["基准情景验证"]:::box
            E4["较优因子识别"]:::box
            E1 --> E2 --> E3 --> E4
        end
        M3 ~~~ E1
    end

    subgraph row4[" "]
        direction LR
        M4["对比实验与敏感性分析法"]:::method
        subgraph p4[" "]
            direction TB
            F1["订单释放与派工规则对比"]:::box
            F2["释放策略对照实验"]:::box
            F3["负荷敏感性分析<br/>与排程方案比选"]:::box
            F1 --> F2 --> F3
        end
        M4 ~~~ F1
    end

    END["结论与展望"]:::endbox

    row1 --> row2 --> row3 --> row4 --> END

    style row1 fill:none,stroke:none,color:none
    style row2 fill:none,stroke:none,color:none
    style row3 fill:none,stroke:none,color:none
    style row4 fill:none,stroke:none,color:none
    style p1 fill:none,stroke:#888888,stroke-width:1px,stroke-dasharray:6 4
    style p2 fill:none,stroke:#888888,stroke-width:1px,stroke-dasharray:6 4
    style p3 fill:none,stroke:#888888,stroke-width:1px,stroke-dasharray:6 4
    style p4 fill:none,stroke:#888888,stroke-width:1px,stroke-dasharray:6 4

    class M1,M2,M3,M4 method
    class END endbox
